# API Server
EXPO_PUBLIC_API_URL=http://localhost:8080

# OAuth - Kakao (네이티브 앱 키)
KAKAO_APP_KEY=your_kakao_native_app_key

# OAuth - Google (iOS 클라이언트 ID)
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=your_google_ios_client_id
# OAuth - Google (Web 클라이언트 ID - 백엔드 토큰 검증용)
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your_google_web_client_id

# OAuth - Naver
NAVER_CONSUMER_KEY=your_naver_client_id
NAVER_CONSUMER_SECRET=your_naver_client_secret

# OAuth - Apple
EXPO_PUBLIC_APPLE_SERVICE_ID=your_apple_service_id

# Naver Map
EXPO_PUBLIC_NAVER_MAP_CLIENT_ID=your_naver_map_client_id
